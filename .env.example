# ===========================================================================
# Stap — environment variables template.
# Copy this file to .env then fill it with the values from the Supabase
# dashboard ("Connect" button > ORMs / Prisma). .env is gitignored: NEVER
# commit secrets there.
# ===========================================================================

# --- Supabase Postgres -----------------------------------------------------
# DATABASE_URL: POOLED connection (Supavisor in transaction mode, port 6543).
#   Used by the application at runtime, through the Prisma driver adapter.
#   ?pgbouncer=true is REQUIRED with the pooler in transaction mode.
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL: DIRECT / session connection (port 5432).
#   Used ONLY by the Prisma CLI (migrations, introspection).
#   Depending on the Supabase project, this is either the session pooler:
#     postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#   or the legacy direct connection:
#     postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# --- Supabase API (step 5: @supabase/ssr) ----------------------------------
# Filled in at step 5. Listed here for reference.
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[anon-public-key]"

# --- Web Push / VAPID (daily reminder push) --------------------------------
# An ECDSA P-256 key pair identifies this app server to browser push services
# (RFC 8292). Generate a pair (e.g. `npx web-push generate-vapid-keys`) and
# place it here AND in the production env (Vercel).
#   NEXT_PUBLIC_VAPID_PUBLIC_KEY: shipped to the client (used at subscribe).
#   VAPID_PRIVATE_KEY: SECRET — server-only, signs each push. Never commit/ship.
#   VAPID_SUBJECT: a mailto: or https: contact for push-service abuse reports.
NEXT_PUBLIC_VAPID_PUBLIC_KEY="[vapid-public-key]"
VAPID_PRIVATE_KEY="[vapid-private-key-secret]"
VAPID_SUBJECT="mailto:you@example.com"

# CRON_SECRET: shared secret protecting the reminder cron endpoint
# (/api/cron/reminders). Vercel Cron sends it as `Authorization: Bearer ...`.
# Generate any high-entropy string (e.g. `openssl rand -base64 24`).
CRON_SECRET="[random-secret]"
