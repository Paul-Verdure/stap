# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# --- Dependencies ----------------------------------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Next.js / Turbopack ---------------------------------------------------
/.next/
/out/
/build
.turbo/
*.tsbuildinfo
next-env.d.ts

# --- Serwist / PWA (generated service worker artifacts) --------------------
# Our setup serves the SW from a Route Handler (in-memory), so nothing is
# written here today — kept for safety if a swDest is ever configured.
/public/sw.js
/public/sw.js.map
/public/swe-worker-*.js

# --- Prisma ----------------------------------------------------------------
# Generated client (regenerated by `prisma generate` / postinstall).
/lib/generated/prisma

# --- Environment -----------------------------------------------------------
# All env files are secret by default; only the template is committed.
.env*
!.env.example

# --- Testing ---------------------------------------------------------------
/coverage

# --- Deployment ------------------------------------------------------------
.vercel

# --- Editors / IDE ---------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo

# --- OS --------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Claude Code (local, machine-specific) ---------------------------------
.claude/settings.local.json
.claude/worktrees/
.claude/launch.json

# --- Logs / debug ----------------------------------------------------------
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
